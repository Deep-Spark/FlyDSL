+def _gpu_launch_func_cluster_kwargs(cluster_size_tuple: Optional[Tuple[Any, Any, Any]]) -> Dict[str, Any]:
+    """Build optional kwargs for `gpu.LaunchFuncOp` cluster launch.
+
+    MLIR Python bindings differ by version: some expose ``cluster_size=`` as a
+    triple, others expose per-axis operands, and some omit cluster entirely.
+    """
+    if cluster_size_tuple is None:
+        return {}
+    sig = inspect.signature(gpu.LaunchFuncOp.__init__)
+    params = sig.parameters
+    if "cluster_size" in params:
+        return {"cluster_size": cluster_size_tuple}
+    if all(f"cluster_size_{ax}" in params for ax in ("x", "y", "z")):
+        x, y, z = cluster_size_tuple
+        return {"cluster_size_x": x, "cluster_size_y": y, "cluster_size_z": z}
+    raise RuntimeError(
+        "This MLIR build's gpu.LaunchFuncOp binding does not support cluster launch; "
+        "pass cluster=None to KernelLauncher.launch() or use MLIR bindings that expose "
+        "cluster operands."
+    )
+
